FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

libs		(overset fvMotionSolvers);

application     overPimpleDyMFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         0.2;

deltaT          0.0001;

adjustTimeStep  yes;
maxCo           0.5;
maxMeshCourant  0.3;
maxDeltaT       0.005;   // optional but recommended
minDeltaT	1E-6;
writeControl    runTime;

writeInterval   0.001;

purgeWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{
    #include "forceCoeffs"
}
