    "pcorr|p"
    {
        solver          PBiCGStab;  // More stable than GAMG for bad meshes
        preconditioner  DILU;
        tolerance       1e-4;       // Don't go tighter than this yet
        relTol          0.01;
    }

    pFinal
    {
        $p;
        relTol          0;
    }

