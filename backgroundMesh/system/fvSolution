PIMPLE
{
    momentumPredictor   no;
    correctPhi          no;
    nOuterCorrectors    5;
    nCorrectors         3;
    nNonOrthogonalCorrectors 0;
    ddtCorr             true;
}

relaxationFactors
{
   equations
    {
        U     0.7; // Lower = more stable, but "lazier" physics
        ".*"  0.7;
    }
    fields
    {
        p     0.3; // Very important for overset stability
    }
}

