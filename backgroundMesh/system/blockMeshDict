FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convertToMeters 0.01;

vertices
(
    //front face

    (60 -70 70) //bottom right
    (60 70 70) //top right
    (-10  70 70) //top left
    (-10  -70 70) //bottom left
    
    //back face
    (60 -70 -70) //bottom right
    (60 70 -70) //top right
    (-10  70 -70) //top left
    (-10  -70 -70) //bottom left
);

blocks
(
    hex (3 0 4 7 2 1 5 6) (25 50 50) simpleGrading (1 1 1)
);

