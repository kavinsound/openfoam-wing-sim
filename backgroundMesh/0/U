FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    outlet_faces
    {
        type    zeroGradient;
        
    }

    inlet
    {
        type    fixedValue;
        value uniform (0 0 1);
    }

    mirror
    {
        type symmetryPlane;
    }

    wing
    {
        type            overset;
    }

    overset_patch
    {
        type            overset;
    }
}

