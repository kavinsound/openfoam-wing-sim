FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      zoneID;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    overset_patch
    {
        type            overset;
        value uniform 0;
    }

    inlet
    {
        type zeroGradient;
    }

    outlet_faces
    {
        type zeroGradient;
    }
    mirror
    {
        type symmetryPlane;
    }

    wing
    {
        
        type zeroGradient;
    }
}

